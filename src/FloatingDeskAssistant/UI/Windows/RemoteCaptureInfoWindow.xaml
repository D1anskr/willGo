<Window x:Class="FloatingDeskAssistant.UI.Windows.RemoteCaptureInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Phone Trigger"
        Width="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#101010">
    <Border Margin="12"
            CornerRadius="16"
            BorderBrush="#40FFFFFF"
            BorderThickness="1"
            Background="#E61B1B1B"
            Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Phone Trigger QR"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="SemiBold" />

            <TextBlock Grid.Row="1"
                       Margin="0,10,0,0"
                       Foreground="#D0D8E6"
                       TextWrapping="Wrap"
                       Text="Use your phone camera or browser to open this page. Then tap one button to trigger host desktop capture while your mouse stays inside VMware." />

            <Border Grid.Row="2"
                    Margin="0,16,0,0"
                    Padding="14"
                    Background="White"
                    CornerRadius="16"
                    HorizontalAlignment="Center">
                <Image x:Name="QrImage"
                       Width="240"
                       Height="240"
                       Stretch="Uniform" />
            </Border>

            <StackPanel Grid.Row="3" Margin="0,16,0,0">
                <TextBlock Text="Primary URL"
                           Foreground="#AFC0D8"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <TextBox x:Name="PrimaryUrlTextBox"
                         Margin="0,6,0,0"
                         IsReadOnly="True"
                         BorderBrush="#55FFFFFF"
                         Background="#22000000"
                         Foreground="White"
                         TextWrapping="Wrap"
                         Padding="10,8" />

                <TextBlock x:Name="StatusTextBlock"
                           Margin="0,10,0,0"
                           Foreground="#D0D8E6"
                           TextWrapping="Wrap" />

                <TextBlock x:Name="OtherUrlsTextBlock"
                           Margin="0,10,0,0"
                           Foreground="#8FB1D8"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />
            </StackPanel>

            <StackPanel Grid.Row="4"
                        Margin="0,18,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Padding="12,8"
                        Margin="0,0,8,0"
                        Content="Copy URL"
                        Click="CopyUrlButton_OnClick" />
                <Button Padding="12,8"
                        Margin="0,0,8,0"
                        Content="Open Page"
                        Click="OpenPageButton_OnClick" />
                <Button Padding="12,8"
                        Content="Close"
                        Click="CloseButton_OnClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
