<Window x:Class="FloatingDeskAssistant.UI.Windows.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FloatingDeskAssistant.UI.Controls"
        Title="Floating Desk Assistant"
        Width="440"
        Height="620"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        PreviewKeyDown="Window_OnPreviewKeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid Margin="8">
        <Border CornerRadius="14"
                BorderBrush="#40FFFFFF"
                BorderThickness="1"
                Background="{Binding WindowBackdropBrush}">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="{Binding HeaderRowHeight}" />
                    <RowDefinition Height="{Binding ConversationRowHeight}" />
                    <RowDefinition Height="{Binding StatusRowHeight}" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10" MouseLeftButtonDown="Header_OnMouseLeftButtonDown" Visibility="{Binding HeaderVisibility}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Desktop Assistant"
                               Foreground="White"
                               FontWeight="SemiBold"
                               FontSize="15"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Clear" Margin="0,0,8,0" Padding="10,4" Command="{Binding ClearSessionCommand}" />
                        <Button Content="{Binding PreferredModelButtonText}" Margin="0,0,8,0" Padding="10,4" Command="{Binding TogglePreferredModelCommand}" />
                        <Button Content="{Binding RemoteCaptureButtonText}" Margin="0,0,8,0" Padding="10,4" Command="{Binding ShowRemoteCaptureInfoCommand}" ToolTip="{Binding RemoteCaptureToolTip}" />
                        <Button Content="Settings" Margin="0,0,8,0" Padding="10,4" Command="{Binding OpenSettingsCommand}" />
                        <Button Content="Hide" Padding="10,4" Click="HideButton_OnClick" />
                    </StackPanel>
                </Grid>

                <Border x:Name="ConversationHostBorder" Grid.Row="1" Background="#33000000" CornerRadius="10" Padding="8" Visibility="{Binding ConversationVisibility}">
                    <Grid x:Name="ConversationContent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel x:Name="CurrentMessageHost" Grid.Row="0" Margin="0,0,0,8" Visibility="Collapsed">
                            <StackPanel x:Name="CurrentMessagePanel" Margin="0,0,0,4">
                                <Border x:Name="CurrentMessageBubble" CornerRadius="10" Padding="10" HorizontalAlignment="Left">
                                    <StackPanel>
                                        <Image x:Name="CurrentMessageImage" Width="220" MaxHeight="200" Stretch="Uniform" Margin="0,0,0,8" Visibility="Collapsed" />
                                        <controls:MessageContentPresenter x:Name="CurrentMessageContentPresenter"
                                                                          DefaultForeground="White"
                                                                          ContentFontSize="{Binding MessageFontSize}" />
                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="CurrentMessageTimestamp"
                                           Margin="4,4,4,0"
                                           Foreground="#DDDDDD"
                                           FontSize="10" />
                            </StackPanel>
                        </StackPanel>

                        <Border x:Name="HistorySeparator" Grid.Row="1" Height="1" Margin="0,0,0,8" Background="#22FFFFFF" Visibility="Collapsed" />

                        <Border x:Name="HistoryHostBorder" Grid.Row="2" Visibility="{Binding HistoryVisibility}">
                            <ScrollViewer x:Name="HistoryScrollViewer" VerticalScrollBarVisibility="Auto" MaxHeight="180">
                                <ItemsControl x:Name="HistoryItemsControl" ItemsSource="{Binding HistoryMessages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,10" HorizontalAlignment="{Binding Alignment}">
                                                <Border MaxWidth="320" CornerRadius="10" Background="{Binding BubbleBrush}" Padding="10">
                                                    <StackPanel>
                                                        <Image Width="220" MaxHeight="200" Stretch="Uniform" Margin="0,0,0,8" Source="{Binding ImageSource}" Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}" />
                                                        <controls:MessageContentPresenter Text="{Binding DisplayText}"
                                                                                          DefaultForeground="{Binding TextBrush}"
                                                                                          ContentFontSize="{Binding DataContext.MessageFontSize, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="{Binding TimestampText}" Margin="4,4,4,0" Foreground="#DDDDDD" FontSize="10" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="2" Margin="0,8,0,0" Foreground="#FFF5C96E" Text="{Binding StatusText}" Visibility="{Binding StatusVisibility}" />

                <Grid Grid.Row="3" Margin="0,8,0,0" Visibility="{Binding FooterVisibility}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Margin="0,0,0,8" Padding="8" CornerRadius="8" BorderBrush="#55FFFFFF" BorderThickness="1" Background="#22000000" Visibility="{Binding PendingImageVisibility}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Image Width="56" Height="56" Stretch="UniformToFill" Margin="0,0,8,0" Source="{Binding PendingImagePreview}" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="White" TextWrapping="Wrap" Text="{Binding PendingImageLabel}" />
                            <Button Grid.Column="2" Margin="8,0,0,0" Padding="10,6" Content="Remove" Command="{Binding RemovePendingImageCommand}" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Margin="0,0,8,0" Padding="12,8" Content="Capture" Command="{Binding CaptureCommand}" Visibility="{Binding StandardActionButtonsVisibility}" />
                        <Button Grid.Column="1" Margin="0,0,8,0" Padding="12,8" Content="Desktop" Command="{Binding CaptureDesktopCommand}" ToolTip="{Binding DesktopButtonToolTip}" />
                        <Button Grid.Column="2" Margin="0,0,8,0" Padding="12,8" Content="Attach" Command="{Binding AttachImageCommand}" Visibility="{Binding StandardActionButtonsVisibility}" />
                        <Button Grid.Column="3" Margin="0,0,8,0" Padding="12,8" Content="{Binding CompactChatModeButtonText}" Command="{Binding ToggleCompactChatModeCommand}" Visibility="{Binding StandardActionButtonsVisibility}" />

                        <TextBox x:Name="InputTextBox"
                                 Grid.Column="4"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="White"
                                 Background="#33000000"
                                 BorderBrush="#66FFFFFF"
                                 Padding="10,8"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MaxHeight="100"
                                 VerticalScrollBarVisibility="Auto"
                                 PreviewKeyDown="InputTextBox_OnPreviewKeyDown" />

                        <StackPanel Grid.Column="5" Orientation="Vertical" Margin="8,0,0,0" Visibility="{Binding SendPanelVisibility}">
                            <Button Margin="0,0,0,6" Padding="12,8" Content="Send" Command="{Binding SendTextCommand}" />
                            <Button Padding="12,8" Content="Retry" Command="{Binding RetryLastRequestCommand}" Visibility="{Binding CanRetryLastRequest, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

