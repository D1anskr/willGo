<Window x:Class="FloatingDeskAssistant.UI.Windows.LatestMessageColumnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FloatingDeskAssistant.UI.Controls"
        Width="420"
        Height="300"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True">
    <Grid Margin="8">
        <Border x:Name="WindowFrame"
                CornerRadius="14"
                BorderBrush="#40FFFFFF"
                BorderThickness="1"
                Background="#DD101010">
            <Border Padding="12">
                <ScrollViewer x:Name="SegmentScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="SegmentPanel" HorizontalAlignment="Left">
                        <Border x:Name="SegmentBubble"
                                CornerRadius="10"
                                Padding="10"
                                HorizontalAlignment="Left"
                                Background="#A02D2D2D">
                            <controls:MessageContentPresenter x:Name="SegmentContentPresenter"
                                                              DefaultForeground="White"
                                                              ContentFontSize="14" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>
    </Grid>
</Window>
